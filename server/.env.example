# MongoDB URI pointing to Percona Server for MongoDB with mongot
MONGODB_URI=mongodb://localhost:27017

# Database and collection names
MONGODB_DB=release_notes
MONGODB_COLLECTION=documents

# Server port
PORT=3000

# Ollama base URL for embedding generation (vector search)
OLLAMA_URL=http://localhost:11434

# Ollama embedding model name
OLLAMA_EMBED_MODEL=nomic-embed-text

# Ollama chat model for AI summaries on vector search (must be pulled via `ollama pull <model>`)
OLLAMA_CHAT_MODEL=llama3.2
